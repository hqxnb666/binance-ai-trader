APP_ENV=development
LOG_LEVEL=INFO

TRADING_MODE=testnet
LIVE_TRADING_ENABLED=false
TRADING_DRY_RUN=true
ORDER_EXECUTION_ENABLED=false

BINANCE_TESTNET_API_KEY=your_testnet_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_secret_here

BINANCE_LIVE_API_KEY=your_live_key_here
BINANCE_LIVE_API_SECRET=your_live_secret_here

OPENAI_API_KEY=your_openai_key_here

OPENAI_DEFAULT_MODEL=gpt-5.4-nano
OPENAI_DIAGNOSTIC_MODEL=gpt-5.4-nano
OPENAI_STRATEGY_MODEL=gpt-5.5
OPENAI_SIGNAL_MODEL=gpt-5.4-mini
OPENAI_TRADE_REVIEW_MODEL=gpt-5.4-mini
OPENAI_DAILY_REPORT_MODEL=gpt-5.4-nano
OPENAI_SYSTEM_AUDITOR_MODEL=gpt-5.4-mini
OPENAI_DEEP_AUDITOR_MODEL=gpt-5.5

OPENAI_STRATEGY_INTERVAL_MINUTES=60
OPENAI_STRATEGY_MAX_OUTPUT_TOKENS=900
OPENAI_SIGNAL_MAX_OUTPUT_TOKENS=450
OPENAI_TRADE_REVIEW_MAX_OUTPUT_TOKENS=600
OPENAI_DAILY_REPORT_MAX_OUTPUT_TOKENS=900
OPENAI_DIAGNOSTIC_MAX_OUTPUT_TOKENS=120
OPENAI_SYSTEM_AUDITOR_MAX_OUTPUT_TOKENS=1000
OPENAI_DEEP_AUDITOR_MAX_OUTPUT_TOKENS=1400

OPENAI_ENABLE_MODEL_FALLBACK=false
OPENAI_FALLBACK_MODELS=gpt-5.4-mini,gpt-5.4

ENABLE_STRATEGY_PLANNER=true
ENABLE_SYSTEM_AUDITOR=true
ENABLE_DEEP_AUDITOR=false

SYSTEM_AUDIT_INTERVAL_MINUTES=120
SYSTEM_AUDIT_LOOKBACK_HOURS=6
SYSTEM_AUDIT_MIN_SEVERITY_TO_HEALTH_WARN=HIGH

SYSTEM_AUDITOR_AUTO_FIX_ALLOWED=false
SYSTEM_AUDITOR_CAN_CALL_CODEX=false
SYSTEM_AUDITOR_CAN_MODIFY_CONFIG=false
SYSTEM_AUDITOR_CAN_MODIFY_STRATEGY=false
SYSTEM_AUDITOR_CAN_PLACE_ORDER=false

OPENAI_DAILY_BUDGET_USD=1
OPENAI_MONTHLY_BUDGET_USD=20
OPENAI_STRATEGY_DAILY_CALL_LIMIT=24
OPENAI_SIGNAL_DAILY_CALL_LIMIT=1000
OPENAI_FAIL_CLOSED_ON_BUDGET_EXCEEDED=true

ENABLE_OPENAI_USAGE_LEDGER=true
ENABLE_BUDGET_GUARD=true

AI_CONTEXT_RECENT_SIGNAL_REVIEWS_LIMIT=20
AI_CONTEXT_RECENT_RISK_DECISIONS_LIMIT=20
AI_CONTEXT_RECENT_ORDERS_LIMIT=20
AI_CONTEXT_RECENT_TRADE_REVIEWS_LIMIT=10
AI_CONTEXT_MAX_JSON_CHARS=24000

# legacy compatibility only
OPENAI_MODEL=

DATABASE_URL=sqlite:///./trading_bot.db

BINANCE_SPOT_TESTNET_REST_BASE=https://testnet.binance.vision/api
BINANCE_SPOT_TESTNET_STREAM_BASE=wss://stream.testnet.binance.vision/ws
BINANCE_SPOT_TESTNET_WS_API_BASE=wss://ws-api.testnet.binance.vision/ws-api/v3

BINANCE_SPOT_LIVE_REST_BASE=https://api.binance.com/api
BINANCE_SPOT_LIVE_STREAM_BASE=wss://stream.binance.com:9443/ws
BINANCE_SPOT_LIVE_WS_API_BASE=wss://ws-api.binance.com:443/ws-api/v3

AI_ANALYSIS_ENABLED=true
AI_CAN_PROPOSE_TRADE=true
AI_CAN_PLACE_ORDER_DIRECTLY=false
